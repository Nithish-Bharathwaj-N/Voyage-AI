# Port settings
PORT=3000

# Environment mode (development, production, test)
NODE_ENV=development

# Database configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/voyageai_dev?schema=public

# Supabase Auth Configuration
# Obtain URL and keys from Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-share-this
SUPABASE_JWT_SECRET=your-supabase-jwt-signing-secret

# Redis Configuration
# Format: redis://HOST:PORT or redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# External Integration API Keys (Optional - features degrade gracefully if absent)
GOOGLE_MAPS_API_KEY=your-google-maps-geocoding-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key
OPENWEATHER_API_KEY=your-openweather-api-key
OPEN_EXCHANGE_RATES_APP_ID=your-open-exchange-rates-app-id
TIMEZONE_API_KEY=your-timezone-api-key
OPENTRIPMAP_API_KEY=your-opentripmap-api-key

# AI/LLM Provider API Keys (Optional - default falls back to mock/local provider if unconfigured)
GEMINI_API_KEY=your-google-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-claude-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

